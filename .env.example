# Copy to .env to enable the multi-device Supabase backend.
# Without these, Matchstick runs fully on-device (AsyncStorage).
#
# 1. Create a project at https://supabase.com
# 2. Run src/supabase/schema.sql in the SQL editor
# 3. Enable Phone auth (Auth → Providers → Phone) with a Twilio/MessageBird key
# 4. Paste your project URL + anon key below
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
